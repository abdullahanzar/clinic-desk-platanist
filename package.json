{
  "name": "clinic-desk-by-platanist",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "build:next": "next build",
    "electron:dev": "node electron/run-dev.cjs",
    "electron:pack": "pnpm run build:next && electron-builder --dir",
    "electron:dist": "pnpm run build:next && electron-builder"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.3.2",
    "bcryptjs": "^3.0.3",
    "jose": "^6.1.3",
    "lucide-react": "^0.562.0",
    "mongodb": "^7.0.0",
    "next": "16.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.platanist.clinicdesk",
    "productName": "Clinic Desk",
    "asar": false,
    "directories": {
      "output": "electron-dist"
    },
    "files": [
      "electron/**/*",
      ".next/standalone/**/*",
      ".next/static/**/*",
      "public/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.medical"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
