{
  "name": "clinic-desk-by-platanist",
  "version": "0.1.0",
  "private": true,
  "author": {
    "name": "Platanist",
    "email": "anzar@platanist.com",
    "url": "https://clinicdesk.platanist.com"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "node scripts/rebuild-db.cjs",
    "build:next": "next build",
    "build:electron": "pnpm run db:generate && pnpm run build:next && node electron/prepare-standalone.cjs",
    "electron:dev": "pnpm run db:generate && node electron/run-dev.cjs",
    "electron:pack": "pnpm run build:electron && electron-builder --dir",
    "electron:dist": "pnpm run build:electron && electron-builder",
    "electron:dist:win": "pnpm run build:electron && electron-builder --win nsis"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.3.2",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.1.3",
    "lucide-react": "^0.562.0",
    "next": "16.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.platanist.clinicdesk",
    "productName": "Clinic Desk",
    "icon": "build/icon.png",
    "asar": true,
    "asarUnpack": [
      ".next/standalone/**/*",
      "drizzle/**/*",
      "public/**/*"
    ],
    "directories": {
      "output": "electron-dist"
    },
    "files": [
      "electron/**/*",
      ".next/standalone/**/*",
      ".next/static/**/*",
      "drizzle/**/*",
      "public/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.medical"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Clinic Desk",
      "runAfterFinish": true,
      "uninstallDisplayName": "Clinic Desk"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
